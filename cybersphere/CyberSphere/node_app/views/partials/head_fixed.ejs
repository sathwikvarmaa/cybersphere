<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle ? pageTitle + ' • CyberSphere' : 'CyberSphere' %></title>
  <link rel="stylesheet" href="/static/css/app.css"/>
</head>
<body class="<%= (typeof pageClass !== 'undefined' ? pageClass : '') %>">
<header class="topbar">
  <div class="brand">
    <span class="brand-mark">◈</span>
    CyberSphere
  </div>
  <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="main-nav" aria-label="Toggle navigation">
    <span></span>
    <span></span>
    <span></span>
  </button>
  <nav class="nav" id="main-nav">
    <a class="nav-link" href="/">Home</a>
    <a class="nav-link" href="/search">Search</a>
    <a class="nav-link" href="/categories">Categories</a>
  </nav>
  <nav class="nav nav-actions">
    <a class="nav-link" href="/profile">Profile</a>
    <a class="nav-link" href="/admin">Admin</a>
  </nav>
</header>

<main class="container">
  <% if (typeof showSearch !== 'undefined' && showSearch) { %>
  <form class="search-inline" method="get" action="/search" style="margin-left:18px;">
    <input class="input" name="q" placeholder="Search posts, authors, categories..." />
  </form>
  <% } %>
