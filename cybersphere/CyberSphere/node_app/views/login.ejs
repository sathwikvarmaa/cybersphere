<%- include('partials/head_fixed', { pageTitle: 'Login', showSearch: false }) %>

<div class="centered">
  <section class="panel glass auth-panel">
    <h2 class="panel-title">Sign in</h2>

    <form class="form" method="post" action="/login">
      <label class="label">Username</label>
      <input class="input" name="username" autocomplete="username" />

      <label class="label">Password</label>
      <input class="input" name="password" type="password" autocomplete="current-password" />

      <button class="btn primary" type="submit">Login</button>

      <div class="row" style="margin-top:12px;">
        <a class="btn" href="/register">Create account</a>
        <a class="btn" href="/reset">Reset password</a>
      </div>
    </form>
  </section>
</div>

<%- include('partials/foot') %>
</html>

